{
  "name": "cordon",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev":     "bun run --cwd packages/gateway dev",
    "test":    "bun test packages/gateway/test packages/sdk/test",
    "lint":    "biome check .",
    "format":  "biome format --write .",
    "build":   "bun run --cwd packages/gateway build && bun run --cwd packages/sdk build",
    "typecheck": "tsc --project packages/gateway/tsconfig.json --noEmit && tsc --project packages/sdk/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2"
  }
}
