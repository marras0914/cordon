{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.marras0914/cordon",
  "title": "Cordon",
  "description": "Security gateway for MCP. Policy enforcement, audit logging, human-in-the-loop approvals.",
  "version": "0.1.10",
  "websiteUrl": "https://getcordon.com",
  "repository": {
    "url": "https://github.com/marras0914/cordon",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "cordon-cli",
      "version": "0.1.10",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "start",
          "description": "Start the Cordon proxy. Reads cordon.config.ts from the current directory."
        }
      ]
    }
  ]
}
