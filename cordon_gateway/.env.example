# Copy to .env and fill in values before running docker-compose.prod.yml
# NEVER commit .env to version control.

# Required
REAL_MCP_SERVER=http://your-mcp-server:8001
POSTGRES_PASSWORD=change-me-strong-password
CORDON_DASHBOARD_KEY=change-me-strong-key
CORDON_SESSION_SECRET=change-me-strong-secret

# Image (set after building/pushing)
CORDON_IMAGE=your-registry/cordon-gateway:0.1.0

# Alerting (optional)
CORDON_WEBHOOK_URL=

# Rate limiting (optional — default 60 calls/min per IP)
CORDON_RATE_LIMIT=60

# OIDC/SSO (optional — uncomment all five to enable)
# CORDON_OIDC_ISSUER=https://login.microsoftonline.com/{tenant}/v2.0
# CORDON_OIDC_CLIENT_ID=
# CORDON_OIDC_CLIENT_SECRET=
# CORDON_OIDC_REDIRECT_URI=https://cordon.example.com/dashboard/auth/callback
# CORDON_OIDC_SCOPES=openid email profile
