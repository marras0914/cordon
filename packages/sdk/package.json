{
  "name": "cordon-sdk",
  "version": "0.1.0",
  "description": "TypeScript client for the Cordon MCP Security Gateway",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run test/",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "keywords": ["mcp", "security", "gateway", "ai", "llm", "policy", "cordon"],
  "author": "marras0914",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marras0914/cordon.git"
  },
  "homepage": "https://github.com/marras0914/cordon",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
